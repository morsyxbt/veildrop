# Copy this file to .env and fill in your values. NEVER commit .env.

# Fresh dev wallet private key (0x-prefixed). Sepolia only — never a real key.
PRIVATE_KEY=

# Sepolia RPC endpoint (full URL from Alchemy, Infura, or a public provider).
# e.g. https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=

# Etherscan API key (for contract verification — optional, can be added later).
ETHERSCAN_API_KEY=

# The frontend uses public RPCs by default (no key in the browser bundle).
# To override in the frontend, create frontend/.env with:
#   VITE_SEPOLIA_RPC_URL=https://your-domain-locked-rpc

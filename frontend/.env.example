# Copy this file to `.env` and fill in the values.
# VITE_-prefixed vars are PUBLIC - they're exposed in the client bundle.
# Real secrets belong in `.env.local` (gitignored via *.local), never here.

# WalletConnect / Reown project id - enables the WalletConnect option in the
# connect modal. Get one free at cloud.reown.com (-> dashboard.walletconnect.com).
# Public value, safe to commit. Add `localhost` (and your prod domain) to the
# project's domain allowlist. Restart the dev server after changing this.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: a dedicated Sepolia RPC URL, tried before the built-in public
# fallbacks (e.g. a domain-locked Alchemy/Infura key in production).
# Leave blank to use the public endpoints.
VITE_SEPOLIA_RPC_URL=

# Optional: override the demo confidential token address. Falls back to the
# deployed Veildrop Demo USD (vUSD) token when blank.
VITE_DEMO_TOKEN=

# ---- Backend (server-side only, NOT exposed to the client) ----
# The campaign store. Set these in your Vercel project env for production.
# Local dev needs neither - the store falls back to an in-memory map.
# Create a free DB at console.upstash.com (Redis) and paste the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Sepolia RPC used by the API to verify a campaign's creator on-chain
# before the first save (one eth_call). Falls back to a public endpoint.
SEPOLIA_RPC_URL=

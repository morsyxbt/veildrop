{
  "name": "veildrop",
  "description": "Veildrop — confidential token distribution (airdrop + disperse) built on the TokenOps SDK and Zama FHEVM",
  "version": "0.1.0",
  "engines": {
    "node": ">=22",
    "npm": ">=7.0.0"
  },
  "license": "MIT",
  "keywords": [
    "fhevm",
    "tokenops",
    "confidential",
    "airdrop",
    "disperse",
    "erc7984",
    "ethereum"
  ],
  "dependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/confidential-contracts": "^0.4.1",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^16.4.5",
    "encrypted-types": "^0.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/mock-utils": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@zama-fhe/relayer-sdk": "^0.4.1",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "ethers": "^6.16.0",
    "globals": "^17.6.0",
    "hardhat": "^2.28.6",
    "hardhat-deploy": "^0.11.45",
    "hardhat-gas-reporter": "^2.3.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "prettier-plugin-solidity": "^2.3.1",
    "rimraf": "^6.1.3",
    "solhint": "^6.2.1",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  },
  "scripts": {
    "clean": "rimraf ./fhevmTemp ./artifacts ./cache ./coverage ./types ./coverage.json ./dist && npm run typechain",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "coverage": "cross-env SOLIDITY_COVERAGE=true hardhat coverage --solcoverjs ./.solcover.js --temp artifacts --testfiles \"test/**/*.ts\" && npm run typechain",
    "lint:sol": "solhint --max-warnings 0 \"contracts/**/*.sol\"",
    "postcompile": "npm run typechain",
    "prettier:check": "prettier --check \"**/*.{js,json,md,sol,ts,yml}\"",
    "prettier:write": "prettier --write \"**/*.{js,json,md,sol,ts,yml}\"",
    "test": "hardhat test",
    "build:ts": "tsc --project tsconfig.json",
    "typechain": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat typechain",
    "deploy:sepolia": "hardhat deploy --network sepolia --tags Token",
    "verify:sepolia": "hardhat verify --network sepolia"
  },
  "overrides": {
    "ws@>=7.0.0 <7.5.10": ">=7.5.10",
    "axios@>=1.3.2 <=1.7.3": ">=1.7.4",
    "elliptic@<6.6.0": ">=6.6.0",
    "micromatch@<4.0.8": ">=4.0.8",
    "undici@>=6.0.0 <6.21.1": ">=6.21.1 <7.0.0",
    "tar-fs@>=2.0.0 <2.1.2": ">=2.1.2",
    "cookie@<0.7.0": ">=0.7.0",
    "minimatch": "^3.1.2"
  }
}
